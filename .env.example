# Template only — copy this file to .env. The app reads .env (not .env.example).
# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
# Set to True to enable Gemini cloud API (System 2). False = 100% local via Ollama.
USE_GEMINI=False
# Ollama local model (System 1) - gemma4:e4b fits perfectly in 8GB VRAM
OLLAMA_MODEL=gemma4:e4b
OLLAMA_TIMEOUT=60  # seconds per LLM call
# Maximum concurrent local System 1 requests. Keep this at 1 on consumer hardware.
SYSTEM_1_MAX_CONCURRENCY=1
# Maximum seconds allowed for a single tool invocation
TOOL_EXEC_TIMEOUT_SECONDS=30
# Total timeout for a full agent turn (covers multi-call chains like PDF extract+summarize)
AGENT_TIMEOUT_SECONDS=300
# Base downloads directory used by file-analysis/PDF skills and prompts
AIDEN_DOWNLOADS_DIR=downloads

# Security Configuration
ADMIN_USER_ID=your_telegram_user_id_here

# Memory Configuration
# Minimum combined user+assistant chars before saving to long-term vector memory
MEMORY_SAVE_THRESHOLD=120
# Memory consolidation interval in seconds (default 6 hours)
MEMORY_CONSOLIDATION_INTERVAL=21600
