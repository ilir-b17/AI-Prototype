# Template only — copy this file to .env. The app reads .env (not .env.example).
# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
# Set to True to enable Gemini cloud API (System 2). False = 100% local via Ollama.
USE_GEMINI=False
# Ollama local model (System 1) - gemma4:e4b fits perfectly in 8GB VRAM
OLLAMA_MODEL=gemma4:e4b
OLLAMA_TIMEOUT=60  # seconds per LLM call
# Maximum concurrent local System 1 requests. Keep this at 1 on consumer hardware.
SYSTEM_1_MAX_CONCURRENCY=1
# Progressive disclosure: inject full SKILL.md body only for tools invoked in the current turn.
ENABLE_SCOPED_SKILL_CONTEXT=true
# Capability-gap migration gate: try matching existing local skills before System 2 synthesis.
ENABLE_LOCAL_SKILL_DISCOVERY_GATE=true
# Maximum seconds allowed for a single tool invocation
TOOL_EXEC_TIMEOUT_SECONDS=30
# Total timeout for a full agent turn (covers multi-call chains like PDF extract+summarize)
AGENT_TIMEOUT_SECONDS=300
# Streaming: seconds before status message appears (0 = always show immediately)
STREAMING_DELAY_SECONDS=2.5
# Streaming: minimum message tokens before streaming is enabled
STREAMING_MIN_TOKENS=4
# Base downloads directory used by file-analysis/PDF skills and prompts
AIDEN_DOWNLOADS_DIR=downloads

# Security Configuration
ADMIN_USER_ID=your_telegram_user_id_here
# Required for MFA-protected core updates. Must be at least 12 characters and must not use common words like blue, password, admin, secret, aiden, or test.
MFA_PASSPHRASE=replace_with_a_strong_authorization_passphrase
# Optional TOTP shared secret for 6-digit MFA codes. Leave empty to use passphrase-only MFA.
MFA_TOTP_SECRET=

# Memory Configuration
# Minimum combined user+assistant chars before saving to long-term vector memory
MEMORY_SAVE_THRESHOLD=60
# Memory consolidation interval in seconds (default 6 hours)
MEMORY_CONSOLIDATION_INTERVAL=21600
# Trigger deep consolidation only every N persisted user turns (helps avoid System 2 rate-limit exhaustion)
CONSOLIDATION_TRIGGER_TURNS=10
# How many days of chat_history rows to retain (older rows are pruned)
CHAT_HISTORY_MAX_DAYS=90
# Minimum rows to keep per user even if older than CHAT_HISTORY_MAX_DAYS
CHAT_HISTORY_MIN_ROWS=20
# How many days of vector memories to retain before pruning
VECTOR_MEMORY_MAX_DAYS=180

# Orchestrator tuning
# Heartbeat interval in seconds (how often the bot processes backlog objectives)
HEARTBEAT_INTERVAL_SECONDS=1800
# Starting energy budget per message or heartbeat cycle
INITIAL_ENERGY_BUDGET=100
# Predictive budget restored at the start of each user turn (prevents permanent depletion)
ENERGY_REPLENISH_PER_TURN=5
# Seconds before abandoned MFA/HITL/tool-approval entries are auto-expired
PENDING_STATE_TTL_SECONDS=86400
# Maximum seconds to wait for a System 1 semaphore slot before timing out
SYSTEM_1_QUEUE_TIMEOUT_SECONDS=120
# LRU cap on per-user async locks (prevents unbounded memory accumulation)
USER_LOCKS_MAX_SIZE=500
# Maximum characters per archival memory chunk injected into prompts
MAX_ARCHIVAL_CHUNK_CHARS=2000
# Maximum total archival memory characters per prompt
MAX_ARCHIVAL_TOTAL_CHARS=12000
# Path to the charter file (default: charter.md in working directory)
CHARTER_PATH=charter.md
# Safety gate: when false, startup fails if charter.md is missing/empty.
# Set to true only to explicitly allow degraded operation without moral evaluation.
ALLOW_MISSING_CHARTER=false
